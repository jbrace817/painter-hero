---
/**
 * PainterHero2 — full-viewport scroll-driven video hero.
 * Video playback is mapped to scroll position so the user
 * "scrubs" through the footage by scrolling down.
 * Uses theme fonts (Newsreader / Manrope) and Material Design 3 palette.
 */
---

<section
  class="painter-hero-2"
  id="painter-hero-2"
  aria-label="Hero — scroll-driven video reveal"
>
  <div class="hero-pin">
    <!-- ── Video background ── -->
    <div class="hero-video-wrap" aria-hidden="true">
      <video
        class="hero-video"
        id="hero2-video"
        data-src="/video/hero.mp4"
        muted
        playsinline
        preload="auto"
        disablepictureinpicture></video>
      <div class="hero-video-scrim"></div>
    </div>

    <!-- ── Film grain ── -->
    <div class="hero-grain" aria-hidden="true"></div>

    <!-- ── Progress bar ── -->
    <div class="hero-progress" aria-hidden="true">
      <div class="hero-progress-fill" id="hero2-progress"></div>
    </div>

    <!-- ── Copy ── -->
    <div class="hero-copy">
      <div class="hero-copy-inner">
        <p class="hero-eyebrow" data-hero2-anim>
          <span class="eyebrow-rule" aria-hidden="true"></span>
          Residential Painting · Bucks County, PA
        </p>

        <h1 class="hero-headline" data-hero2-anim>
          Meticulous Craftsmanship.<br /><em>Stunning</em> Results.
        </h1>

        <p class="hero-sub" data-hero2-anim>
          Professional interior and exterior painting for homeowners across
          Doylestown and the surrounding townships. Twenty years of patient,
          perfectionist work&nbsp;— and the five-star neighbors to prove it.
        </p>

        <div class="hero-actions" data-hero2-anim>
          <a href="#contact" class="btn-primary">Get a Free Estimate</a>
          <a href="#portfolio" class="btn-outline">See Recent Work</a>
        </div>
      </div>

      <div class="scroll-cue" id="hero2-scroll-cue" data-hero2-anim>
        <span class="scroll-cue-label">Scroll to play</span>
        <svg
          class="scroll-cue-arrow"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M4.5 7L9 11.5L13.5 7"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  /* ───────── Scaffold ───────── */

  .painter-hero-2 {
    --ph2-accent: var(--color-primary, #765a23);
    --ph2-accent-bright: var(--color-tertiary, #7d5800);
    --ph2-runway: 600vh;
    position: relative;
    height: var(--ph2-runway);
    isolation: isolate;
  }

  @media (max-width: 767px) {
    .painter-hero-2 {
      --ph2-runway: 400vh;
    }
  }

  .hero-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  /* ───────── Video layer ───────── */

  .hero-video-wrap {
    position: absolute;
    inset: 0;
  }

  .hero-video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-video-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(27, 28, 25, 0.35) 0%,
      rgba(27, 28, 25, 0.15) 40%,
      rgba(27, 28, 25, 0.45) 100%
    );
    pointer-events: none;
  }

  /* ───────── Grain overlay ───────── */

  .hero-grain {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    opacity: 0.04;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* ───────── Progress bar ───────── */

  .hero-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(255, 255, 255, 0.1);
    z-index: 12;
  }

  .hero-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--ph2-accent-bright);
    transition: width 0.05s linear;
  }

  /* ───────── Copy ───────── */

  .hero-copy {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .hero-copy::before {
    content: "";
    position: absolute;
    width: 130%;
    height: 65%;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 0.32) 0%,
      transparent 72%
    );
    pointer-events: none;
  }

  .hero-copy-inner {
    position: relative;
    max-width: 780px;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.55);
    margin-bottom: 1.75rem;
  }

  .eyebrow-rule {
    display: block;
    width: 1.75rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.35);
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-headline);
    font-size: clamp(2.5rem, 5.5vw + 0.5rem, 5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: #fff;
    text-shadow:
      0 2px 20px rgba(0, 0, 0, 0.5),
      0 1px 3px rgba(0, 0, 0, 0.4);
    margin-bottom: 1.5rem;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--color-teal-300, #a6deda);
  }

  /* Subheadline */
  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 1vw + 0.5rem, 1.125rem);
    font-weight: 400;
    line-height: 1.72;
    color: rgba(255, 255, 255, 0.88);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
    max-width: 560px;
    margin: 0 auto 2.75rem;
  }

  /* ───────── Actions ───────── */

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    padding: 0.875rem 1.875rem;
    transition:
      transform 0.24s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s,
      border-color 0.2s,
      box-shadow 0.24s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--ph2-accent);
    color: var(--color-on-primary, #fff);
    box-shadow: 0 2px 12px rgba(118, 90, 35, 0.4);
  }
  .btn-primary:hover {
    background: var(--ph2-accent-bright);
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(118, 90, 35, 0.5);
  }
  .btn-primary:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
    box-shadow: 0 0 0 4px rgba(118, 90, 35, 0.45);
  }

  .btn-outline {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.6);
    transform: scale(1.04);
  }
  .btn-outline:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  @media (max-width: 767px) {
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
    .btn-primary,
    .btn-outline {
      width: 100%;
      max-width: 300px;
    }
  }

  /* ───────── Scroll cue ───────── */

  .scroll-cue {
    position: absolute;
    bottom: 2.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .scroll-cue-label {
    font-family: var(--font-label);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .scroll-cue-arrow {
    animation: cue-bounce 2.4s ease-in-out infinite;
  }

  @keyframes cue-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(5px);
    }
  }

  /* ───────── Entrance animations ───────── */

  [data-hero2-anim] {
    opacity: 0;
    transform: translateY(32px);
    animation: hero2-enter 0.85s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  [data-hero2-anim]:nth-child(1) {
    animation-delay: 0.3s;
  }
  [data-hero2-anim]:nth-child(2) {
    animation-delay: 0.43s;
  }
  [data-hero2-anim]:nth-child(3) {
    animation-delay: 0.56s;
  }
  [data-hero2-anim]:nth-child(4) {
    animation-delay: 0.69s;
  }
  [data-hero2-anim]:nth-child(5) {
    animation-delay: 0.82s;
  }

  @keyframes hero2-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ───────── Reduced motion ───────── */

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue {
      display: none;
    }
    .scroll-cue-arrow {
      animation: none;
    }
    [data-hero2-anim] {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  function shouldScrubVideo(): boolean {
    const isCoarsePointer = window.matchMedia("(pointer: coarse)").matches;
    const cannotHover = window.matchMedia("(hover: none)").matches;

    if (!isCoarsePointer && !cannotHover) return true;

    const cores = navigator.hardwareConcurrency || 2;
    const memory = (navigator as any).deviceMemory || 2;

    return cores >= 6 && memory >= 6;
  }

  function initHero2() {
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const hero = document.getElementById("painter-hero-2");
    const video = document.getElementById("hero2-video") as HTMLVideoElement;
    const progressBar = document.getElementById("hero2-progress");
    const scrollCue = document.getElementById("hero2-scroll-cue");

    if (!hero || !video) return;

    const videoUrl = video.dataset.src;
    if (!videoUrl) return;

    if (reducedMotion) {
      video.src = videoUrl;
      video.pause();
      return;
    }

    if (!shouldScrubVideo()) {
      initPlayMode(hero, video, videoUrl, progressBar, scrollCue);
      return;
    }

    initScrubMode(hero, video, videoUrl, progressBar, scrollCue);
  }

  /* ── Mobile / weak-device path: auto-play on visibility ── */

  function initPlayMode(
    hero: HTMLElement,
    video: HTMLVideoElement,
    videoUrl: string,
    progressBar: HTMLElement | null,
    scrollCue: HTMLElement | null,
  ) {
    hero.style.height = "100vh";

    if (progressBar?.parentElement) {
      progressBar.parentElement.style.display = "none";
    }
    if (scrollCue) scrollCue.style.display = "none";

    video.src = videoUrl;
    video.loop = false;

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          video.play().catch(() => {});
          observer.disconnect();
        }
      },
      { threshold: 0.25 },
    );
    observer.observe(hero);
  }

  /* ── Desktop path: scroll-driven video scrubbing ── */

  function initScrubMode(
    hero: HTMLElement,
    video: HTMLVideoElement,
    videoUrl: string,
    progressBar: HTMLElement | null,
    scrollCue: HTMLElement | null,
  ) {
    let videoReady = false;
    let videoDuration = 0;
    let ticking = false;
    let objectUrl: string | null = null;
    let pendingTarget = -1;
    let seeking = false;

    function computeProgress() {
      const rect = hero.getBoundingClientRect();
      const runway = hero.offsetHeight - window.innerHeight;
      if (runway <= 0) return 0;
      const scrolled = Math.max(0, -rect.top);
      return Math.min(1, scrolled / runway);
    }

    function applyUiProgress(progress: number) {
      if (progressBar) {
        progressBar.style.width = `${(progress * 100).toFixed(1)}%`;
      }
      if (scrollCue) {
        scrollCue.style.opacity = String(
          Math.max(0, 1 - progress * 7).toFixed(3),
        );
      }
      const copyInner = hero.querySelector(".hero-copy-inner") as HTMLElement;
      if (copyInner) {
        const copyFade = Math.max(0, 1 - progress * 2.5);
        copyInner.style.opacity = String(copyFade.toFixed(3));
        copyInner.style.transform = `translateY(${(-progress * 60).toFixed(1)}px)`;
      }
    }

    function seekToPending() {
      if (!videoReady || videoDuration <= 0) return;
      if (pendingTarget < 0) return;
      if (seeking) return;
      const target = pendingTarget;
      pendingTarget = -1;
      if (Math.abs(video.currentTime - target) < 0.02) return;
      seeking = true;
      try {
        video.currentTime = target;
      } catch {
        seeking = false;
      }
    }

    video.addEventListener("seeked", () => {
      seeking = false;
      if (pendingTarget >= 0) seekToPending();
    });

    function onFrame() {
      ticking = false;
      const progress = computeProgress();
      applyUiProgress(progress);
      if (videoReady && videoDuration > 0) {
        pendingTarget = progress * videoDuration;
        seekToPending();
      }
    }

    function onVideoReady() {
      if (videoReady) return;
      videoReady = true;
      videoDuration = video.duration;
      video.pause();
      video.currentTime = 0;
      onFrame();
    }

    async function loadVideo() {
      try {
        const res = await fetch(videoUrl, { credentials: "same-origin" });
        if (!res.ok) throw new Error(`Fetch failed: ${res.status}`);
        const blob = await res.blob();
        objectUrl = URL.createObjectURL(blob);
        video.src = objectUrl;
      } catch {
        video.src = videoUrl;
      }

      if (video.readyState >= 2) {
        onVideoReady();
      } else {
        video.addEventListener("loadeddata", onVideoReady, { once: true });
        video.addEventListener("canplay", onVideoReady, { once: true });
      }
    }

    loadVideo();

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(onFrame);
        }
      },
      { passive: true },
    );

    window.addEventListener("resize", () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(onFrame);
      }
    });

    window.addEventListener("beforeunload", () => {
      if (objectUrl) URL.revokeObjectURL(objectUrl);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHero2);
  } else {
    initHero2();
  }
</script>
