---
function getYear() {
  return new Date().getFullYear();
}
---

<footer
  class="bg-on-secondary-fixed-variant text-surface font-body mt-12 w-full font-light tracking-wide sm:mt-16"
>
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-4 py-14 sm:px-6 sm:py-16 md:grid-cols-3 md:py-20 lg:gap-12 lg:px-8"
  >
    <div>
      <span
        class="font-headline text-primary-container mb-4 block text-2xl sm:mb-6 sm:text-3xl"
        >Bucks County Painters</span
      >
      <p class="text-surface/80 max-w-xs text-sm leading-relaxed sm:text-base">
        Fine architectural painting and restoration for distinguished homes in
        Pennsylvania.
      </p>
      <div class="mt-6 flex items-center gap-4 sm:mt-8">
        <span class="material-symbols-outlined text-primary-container"
          >phone</span
        >
        <span class="text-sm sm:text-base">(215) 555-0123</span>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-6 sm:gap-8">
      <div class="space-y-3 sm:space-y-4">
        <h4
          class="text-primary-container mb-4 text-[10px] font-bold tracking-[0.2em] uppercase sm:mb-6 sm:text-xs"
        >
          Navigation
        </h4>
        <a
          class="text-surface/80 hover:text-primary-container block text-sm transition-colors duration-300 sm:text-base"
          href="#">Portfolio</a
        >
        <a
          class="text-surface/80 hover:text-primary-container block text-sm transition-colors duration-300 sm:text-base"
          href="#">Residential</a
        >
        <a
          class="text-surface/80 hover:text-primary-container block text-sm transition-colors duration-300 sm:text-base"
          href="#">Commercial</a
        >
      </div>
      <div class="space-y-3 sm:space-y-4">
        <h4
          class="text-primary-container mb-4 text-[10px] font-bold tracking-[0.2em] uppercase sm:mb-6 sm:text-xs"
        >
          Legal
        </h4>
        <a
          class="text-surface/80 hover:text-primary-container block text-sm transition-colors duration-300 sm:text-base"
          href="#">Privacy Policy</a
        >
        <a
          class="text-surface/80 hover:text-primary-container block text-sm transition-colors duration-300 sm:text-base"
          href="#">Terms of Service</a
        >
      </div>
    </div>

    <div>
      <h4
        class="text-primary-container mb-4 text-[10px] font-bold tracking-[0.2em] uppercase sm:mb-6 sm:text-xs"
      >
        Credential
      </h4>
      <p
        class="text-surface/80 mb-4 text-sm leading-relaxed sm:mb-6 sm:text-base"
      >
        &copy; {getYear()} Bucks County Painters. Fully Licensed &amp; Insured. PA#123456
      </p>
      <div class="flex gap-4">
        <div
          class="border-surface/20 hover:bg-primary-container hover:text-primary flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border transition-all sm:h-10 sm:w-10"
        >
          <span class="material-symbols-outlined text-sm">public</span>
        </div>
        <div
          class="border-surface/20 hover:bg-primary-container hover:text-primary flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border transition-all sm:h-10 sm:w-10"
        >
          <span class="material-symbols-outlined text-sm">alternate_email</span>
        </div>
      </div>
    </div>
  </div>
</footer>
