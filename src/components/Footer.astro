---
function getYear() {
  return new Date().getFullYear();
}
---

<footer class="site-footer">
  <div class="mx-auto max-w-[1280px] px-5 sm:px-8">
    <div class="footer-grid">
      <div>
        <div class="font-headline text-2xl text-cream tracking-[0.01em] mb-3">Bucks County Painters</div>
        <p class="max-w-[38ch] text-sm leading-[1.6] text-cream/75 mb-5">
          Owner-led residential painting in central Bucks County, PA.
          Meticulous prep, premium paints, and a two-year workmanship
          guarantee on every project.
        </p>
        <div class="flex gap-2.5">
          <a href="#" aria-label="Google" class="social-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l2.9 6.9L22 10l-5.5 4.8L18 22l-6-3.5L6 22l1.5-7.2L2 10l7.1-1.1z" />
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="social-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
            </svg>
          </a>
          <a href="#" aria-label="Facebook" class="social-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22 12a10 10 0 10-11.6 9.9v-7H8v-3h2.4V9.5c0-2.4 1.4-3.7 3.6-3.7 1 0 2.1.2 2.1.2v2.3h-1.2c-1.2 0-1.5.7-1.5 1.5V12h2.6l-.4 3h-2.2v7A10 10 0 0022 12z" />
            </svg>
          </a>
        </div>
      </div>
      <div>
        <h5 class="footer-heading">Services</h5>
        <ul class="footer-links">
          <li><a href="#">Interior painting</a></li>
          <li><a href="#">Exterior painting</a></li>
          <li><a href="#">Decks &amp; outbuildings</a></li>
          <li><a href="#">Cabinet refinishing</a></li>
          <li><a href="#">Drywall repair</a></li>
        </ul>
      </div>
      <div>
        <h5 class="footer-heading">Company</h5>
        <ul class="footer-links">
          <li><a href="#about">About Ben</a></li>
          <li><a href="#portfolio">Portfolio</a></li>
          <li><a href="#reviews">Reviews</a></li>
          <li><a href="#area">Service area</a></li>
          <li><a href="#contact">Get estimate</a></li>
        </ul>
      </div>
      <div>
        <h5 class="footer-heading">Contact</h5>
        <ul class="footer-links">
          <li>(267) 810-3352</li>
          <li>ben@buckscountypainters.com</li>
          <li>Doylestown, PA 18901</li>
          <li>Mon–Fri · 7am–6pm</li>
        </ul>
      </div>
    </div>
    <div class="footer-legal">
      <span>&copy; {getYear()} Bucks County Painters LLC · PA HIC #PA######</span>
      <span>
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Accessibility</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink, #0e2a2b);
    color: rgba(251,248,241,0.75);
    padding: 72px 0 40px;
    font-size: 14px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-heading {
    color: var(--color-cream, #fbf8f1);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 18px;
  }
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-links li { margin-bottom: 10px; }
  .footer-links a:hover { color: var(--color-teal-400); }
  .social-icon {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(251,248,241,0.2);
    border-radius: 50%;
    transition: all 0.2s ease;
  }
  .social-icon:hover {
    border-color: var(--color-teal-400);
    color: var(--color-teal-400);
  }
  .footer-legal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    border-top: 1px solid rgba(251,248,241,0.1);
    font-size: 12px;
    color: rgba(251,248,241,0.5);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }
  .footer-legal a { margin-left: 20px; }
  .footer-legal a:hover { color: var(--color-teal-400); }

  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .footer-legal {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>
