} = Astro.props;
---

<CircularPortfolio
  items={items}
  label={label}
  heading={heading}
  autoplay={autoplay}
  client:visible
/>

<style is:global>
  .cp-section {
    padding: 4rem 0;
  }
  @media (min-width: 640px) {
    .cp-section {
      padding: 5rem 0;
    }
  }
  @media (min-width: 768px) {
    .cp-section {
      padding: 6rem 0;
    }
  }
  @media (min-width: 1024px) {
    .cp-section {
      padding: 7rem 0;
    }
  }

  .cp-wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  @media (min-width: 640px) {
    .cp-wrapper {
      padding: 0 2rem;
    }
  }

  .cp-header {
    margin-bottom: 3.5rem;
    text-align: center;
  }

  .cp-label {
    display: block;
    margin-bottom: 0.875rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal-600);
  }

  .cp-heading {
    font-family: var(--font-headline);
    color: var(--color-ink);
    font-size: clamp(32px, 3.6vw, 48px);
    line-height: 1.08;
    font-weight: 400;
  }

  .cp-grid {
    display: grid;
    gap: 3rem;
    max-width: 56rem;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .cp-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
  }

  .cp-images {
    position: relative;
    width: 100%;
    height: 20rem;
    perspective: 1000px;
  }
  @media (min-width: 640px) {
    .cp-images {
      height: 24rem;
    }
  }

  .cp-image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.75rem;
    box-shadow: 0 10px 30px rgba(14, 42, 43, 0.2);
  }

  .cp-content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 16rem;
  }

  .cp-title {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .cp-location {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-teal-600);
    margin-bottom: 1.5rem;
  }

  .cp-description {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-warm-gray);
  }

  .cp-word {
    display: inline-block;
  }

  .cp-arrows {
    display: flex;
    gap: 1rem;
    padding-top: 2rem;
  }
  @media (min-width: 768px) {
    .cp-arrows {
      padding-top: 0;
    }
  }

  .cp-arrow {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.3s ease;
    border: none;
    outline: none;
  }
  .cp-arrow:focus-visible {
    outline: 2px solid var(--color-teal-400);
    outline-offset: 2px;
  }
</style>
