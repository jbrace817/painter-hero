---
import CircularPortfolio from "./CircularPortfolio";

interface PortfolioItem {
  title: string;
  location: string;
  description: string;
  src: string;
}

interface Props {
  label?: string;
  heading?: string;
  items?: PortfolioItem[];
  autoplay?: boolean;
}

const {
  label = "Recent work",
  heading = "A few projects from this year.",
  autoplay = true,
  items = [
    {
      src: "https://res.cloudinary.com/dsjx8ner3/image/upload/v1777319022/interior3_a66kvh.jpg",
      title: "Exterior",
      location: "Doylestown · Exterior",
      description:
        "A complete transformation of this 1920s colonial living room. We restored the original crown molding and applied a warm, heritage-inspired palette that honors the home's character while feeling fresh and contemporary.",
    },
    {
      src: "https://res.cloudinary.com/dsjx8ner3/image/upload/v1777319025/exterior_mkapsn.jpg",
      title: "Cape Cod exterior",
      location: "New Hope · Exterior",
      description:
        "Full exterior repaint on this classic Cape Cod. We prepped every surface by hand, replaced rotted trim, and applied a crisp white with deep navy shutters that makes this home the standout on the street.",
    },
    {
      src: "https://res.cloudinary.com/dsjx8ner3/image/upload/v1777319025/decks_dzo8rk.jpg",
      title: "Cedar deck refinish",
      location: "Warrington · Deck",
      description:
        "This weathered cedar deck was brought back to life with a thorough sanding, stain stripping, and two coats of a semi-transparent teak stain. The result is a warm, inviting outdoor space that looks brand new.",
    },
    {
      src: "https://res.cloudinary.com/dsjx8ner3/image/upload/v1777319021/kitchen_o1wydg.jpg",
      title: "White oak cabinets",
      location: "Solebury · Cabinetry",
      description:
        "Custom cabinet refinishing in white oak. We stripped the old lacquer, sanded to bare wood, and applied a hand-rubbed oil finish that highlights the natural grain while providing lasting protection.",
    },
    {
      src: "https://res.cloudinary.com/dsjx8ner3/image/upload/v1777319024/exterior2_rq2ted.jpg",
      title: "Farmhouse siding",
      location: "Plumstead · Exterior",
      description:
        "A beautiful farmhouse exterior refresh. We repaired aging clapboard siding, primed with a high-adhesion primer, and finished with two coats of durable acrylic in a classic sage green.",
    },
    {
      src: "https://res.cloudinary.com/dsjx8ner3/image/upload/v1777319021/kitchen_o1wydg.jpg",
      title: "Kitchen refresh",
      location: "Buckingham · Interior",
      description:
        "This kitchen got a complete color overhaul with rich navy cabinets, bright white walls, and brass hardware accents. The deep tones pair beautifully with the marble countertops for a timeless look.",
    },
  ],
} = Astro.props;
---

<CircularPortfolio
  items={items}
  label={label}
  heading={heading}
  autoplay={autoplay}
  client:visible
/>

<style is:global>
  .cp-section {
    padding: 4rem 0;
  }
  @media (min-width: 640px) {
    .cp-section {
      padding: 5rem 0;
    }
  }
  @media (min-width: 768px) {
    .cp-section {
      padding: 6rem 0;
    }
  }
  @media (min-width: 1024px) {
    .cp-section {
      padding: 7rem 0;
    }
  }

  .cp-wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  @media (min-width: 640px) {
    .cp-wrapper {
      padding: 0 2rem;
    }
  }

  .cp-header {
    margin-bottom: 8rem;
    text-align: center;
  }

  .cp-label {
    display: block;
    margin-bottom: 0.875rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal-600);
  }

  .cp-heading {
    font-family: var(--font-headline);
    color: var(--color-ink);
    font-size: clamp(32px, 3.6vw, 48px);
    line-height: 1.08;
    font-weight: 400;
  }

  .cp-grid {
    display: grid;
    gap: 3rem;
    max-width: 56rem;
    margin: 0 auto;
  }
  @media (min-width: 1025px) {
    .cp-grid {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2.5rem, 5vw, 4.5rem);
      align-items: center;
      max-width: none;
    }
  }

  .cp-images {
    position: relative;
    width: 100%;
    height: 20rem;
    perspective: 1000px;
  }
  @media (min-width: 640px) {
    .cp-images {
      height: 24rem;
    }
  }
  @media (min-width: 768px) {
    .cp-images {
      height: 28rem;
    }
  }
  /* Tablet: images are 80% width of this box — set height from width so cards read near-square */
  @media (min-width: 768px) and (max-width: 1024px) {
    .cp-images {
      height: auto;
      aspect-ratio: 1.25;
    }
  }
  @media (min-width: 1025px) {
    .cp-images {
      height: 24rem;
    }
  }

  .cp-image {
    position: absolute;
    width: 80%;
    height: 100%;
    left: 10%;
    object-fit: cover;
    border-radius: 0.75rem;
    box-shadow: 0 10px 30px rgba(14, 42, 43, 0.2);
  }

  .cp-right {
    display: flex;
    flex-direction: column-reverse;
    gap: 0;
  }

  @media (min-width: 1025px) {
    .cp-right {
      flex-direction: column;
      justify-content: space-between;
      min-height: 20rem;
    }
  }

  /* Reserves space so slide copy changes do not move images or controls */
  .cp-text {
    min-height: 16rem;
  }
  @media (min-width: 1025px) {
    .cp-text {
      min-height: 16rem;
    }
  }

  .cp-title {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .cp-location {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-teal-600);
    margin-bottom: 1.5rem;
  }

  .cp-description {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-warm-gray);
  }

  .cp-word {
    display: inline-block;
  }

  .cp-arrows {
    display: flex;
    gap: 1rem;
    width: fit-content;
    max-width: 100%;
  }

  @media (max-width: 1024px) {
    .cp-arrows {
      align-self: center;
      padding-bottom: 3.75rem;
    }
  }

  @media (min-width: 1025px) {
    .cp-arrows {
      padding-top: 0;
    }
  }

  .cp-arrow {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.3s ease;
    border: none;
    outline: none;
  }
  .cp-arrow:focus-visible {
    outline: 2px solid var(--color-teal-400);
    outline-offset: 2px;
  }
</style>
