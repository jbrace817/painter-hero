---
/**
 * PainterHero — full-viewport scroll-driven before/after reveal.
 * Diagonal clip-path wipe controlled by scroll position.
 * Motion One entrance animations. Zero React. Zero islands.
 */
---

<section
  class="painter-hero"
  id="painter-hero"
  aria-label="Hero — before and after painting reveal"
>
  <div class="hero-pin">
    <!-- ── BEFORE: faded, neglected exterior ── -->
    <div class="hero-layer layer-before" aria-hidden="true">
      <img
        class="hero-img"
        src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=1920&h=1080&fit=crop&crop=center&q=80&auto=format"
        alt="House exterior before painting — faded and worn"
        fetchpriority="high"
        loading="eager"
      />
    </div>

    <!-- ── AFTER: vibrant, freshly painted ── -->
    <div class="hero-layer layer-after" id="hero-after" aria-hidden="true">
      <img
        class="hero-img"
        src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=1920&h=1080&fit=crop&crop=center&q=80&auto=format"
        alt="House exterior after painting — fresh and vibrant"
        loading="eager"
      />
    </div>

    <!-- ── Paint roller (tracks the wipe edge) ── -->
    <div class="paint-roller" id="hero-roller" aria-hidden="true">
      <img
        src="/images/roller.png"
        alt=""
        class="roller-img"
        loading="eager"
        draggable="false"
      />
    </div>

    <!-- ── Film grain ── -->
    <div class="hero-grain" aria-hidden="true"></div>

    <!-- ── Copy ── -->
    <div class="hero-copy">
      <div class="hero-copy-inner">
        <p class="hero-eyebrow" data-hero-anim>
          <span class="eyebrow-rule" aria-hidden="true"></span>
          Residential &amp; Commercial Painting
        </p>

        <h1 class="hero-headline" data-hero-anim>
          Your Home's Next Chapter<br />Starts With Color
        </h1>

        <p class="hero-sub" data-hero-anim>
          Interior. Exterior. Cabinet refinishing. We transform spaces across
          Bucks County&nbsp;— and you'll see the difference before we even pick
          up a brush.
        </p>

        <div class="hero-actions" data-hero-anim>
          <a href="#estimate" class="btn-primary">Get Your Free Estimate</a>
          <a href="#portfolio" class="btn-outline">See Our Work</a>
        </div>
      </div>

      <div class="scroll-cue" id="hero-scroll-cue" data-hero-anim>
        <span class="scroll-cue-label">Scroll to reveal</span>
        <svg
          class="scroll-cue-arrow"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M4.5 7L9 11.5L13.5 7"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap");

  /* ───────── Scaffold ───────── */

  .painter-hero {
    --ph-brand: #e85d2a;
    --ph-brand-hot: #d14e1f;
    --ph-runway: 250vh;
    position: relative;
    height: var(--ph-runway);
    isolation: isolate;
  }

  @media (max-width: 767px) {
    .painter-hero {
      --ph-runway: 180vh;
    }
  }

  .hero-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  /* ───────── Image layers ───────── */

  .hero-layer {
    position: absolute;
    inset: 0;
  }

  .hero-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  /* Before — desaturated, dark, yellowed */
  .layer-before {
    background: #1e1a16;
  }
  .layer-before .hero-img {
    filter: saturate(0.1) brightness(0.48) contrast(0.82) sepia(0.25);
  }
  .layer-before::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(25, 18, 12, 0.58) 0%,
      rgba(10, 12, 22, 0.32) 100%
    );
  }

  /* After — vibrant, fresh, sharp */
  .layer-after {
    background: #eee5d8;
    clip-path: polygon(0% 0%, 0% 0%, 0% 0%);
    will-change: clip-path;
    z-index: 2;
  }
  .layer-after .hero-img {
    filter: saturate(1.22) brightness(1.08) contrast(1.08);
  }

  /* ───────── Grain overlay ───────── */

  .hero-grain {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    opacity: 0.045;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* ───────── Copy ───────── */

  .hero-copy {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  /* Radial vignette behind text for legibility over bright "after" image */
  .hero-copy::before {
    content: "";
    position: absolute;
    width: 130%;
    height: 65%;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 0.3) 0%,
      transparent 72%
    );
    pointer-events: none;
  }

  .hero-copy-inner {
    position: relative;
    max-width: 780px;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.55);
    margin-bottom: 1.75rem;
  }

  .eyebrow-rule {
    display: block;
    width: 1.75rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.35);
  }

  /* Headline */
  .hero-headline {
    font-family: "Instrument Serif", Georgia, "Times New Roman", serif;
    font-size: clamp(2.5rem, 5.5vw + 0.5rem, 5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: #fff;
    text-shadow:
      0 2px 20px rgba(0, 0, 0, 0.5),
      0 1px 3px rgba(0, 0, 0, 0.4);
    margin-bottom: 1.5rem;
  }

  /* Subheadline */
  .hero-sub {
    font-size: clamp(0.9375rem, 1vw + 0.5rem, 1.125rem);
    font-weight: 400;
    line-height: 1.72;
    color: rgba(255, 255, 255, 0.8);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
    max-width: 560px;
    margin: 0 auto 2.75rem;
  }

  /* ───────── Actions ───────── */

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    padding: 0.875rem 1.875rem;
    transition:
      transform 0.24s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s,
      border-color 0.2s,
      box-shadow 0.24s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--ph-brand);
    color: #fff;
    box-shadow: 0 2px 12px rgba(232, 93, 42, 0.4);
  }
  .btn-primary:hover {
    background: var(--ph-brand-hot);
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(232, 93, 42, 0.5);
  }
  .btn-primary:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
    box-shadow: 0 0 0 4px rgba(232, 93, 42, 0.45);
  }

  .btn-outline {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.6);
    transform: scale(1.04);
  }
  .btn-outline:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  @media (max-width: 767px) {
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
    .btn-primary,
    .btn-outline {
      width: 100%;
      max-width: 300px;
    }
  }

  /* ───────── Scroll cue ───────── */

  .scroll-cue {
    position: absolute;
    bottom: 2.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .scroll-cue-label {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .scroll-cue-arrow {
    animation: cue-bounce 2.4s ease-in-out infinite;
  }

  @keyframes cue-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(5px);
    }
  }

  /* ───────── Paint roller ───────── */

  .paint-roller {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 5;
    width: clamp(80px, 14vw, 180px);
    height: auto;
    pointer-events: none;
    opacity: 0;
    will-change: transform, opacity;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.5))
      drop-shadow(0 0 6px rgba(0, 0, 0, 0.2));
  }

  .roller-img {
    display: block;
    width: 100%;
    height: auto;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* ───────── Reduced motion ───────── */

  @media (prefers-reduced-motion: reduce) {
    .layer-after {
      clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%) !important;
      will-change: auto;
    }
    .paint-roller {
      display: none;
    }
    .scroll-cue {
      display: none;
    }
    .scroll-cue-arrow {
      animation: none;
    }
    [data-hero-anim] {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  import { animate } from "motion";

  const reducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const hero = document.getElementById("painter-hero");
  const afterLayer = document.getElementById("hero-after");
  const scrollCue = document.getElementById("hero-scroll-cue");
  const rollerEl = document.getElementById("hero-roller");

  if (hero && afterLayer && !reducedMotion) {
    /* ── Staggered entrance ── */

    const animEls = document.querySelectorAll<HTMLElement>("[data-hero-anim]");

    animEls.forEach((el, i) => {
      el.style.opacity = "0";
      el.style.transform = "translateY(32px)";

      animate(
        el,
        { opacity: [0, 1], transform: ["translateY(32px)", "translateY(0)"] },
        {
          duration: 0.85,
          easing: [0.22, 1, 0.36, 1],
          delay: 0.3 + i * 0.13,
        },
      );
    });

    /* ── Diagonal clip-path wipe ──
     *
     * The "after" layer is revealed via a polygon that expands from the
     * top-left corner diagonally toward the bottom-right as scroll
     * progress goes from 0 → 1.
     *
     * Phase 1 (progress 0–0.5): A triangle grows from the corner.
     * Phase 2 (progress 0.5–1): The triangle fills out into the full rect.
     *
     * A paint roller SVG tracks the midpoint of the wipe edge, rotated
     * perpendicular to the viewport diagonal so it looks like the roller
     * is painting the reveal.
     */

    function clipAt(p: number): string {
      if (p <= 0) return "polygon(0% 0%, 0% 0%, 0% 0%)";
      if (p >= 1) return "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)";

      const d = p * 2;

      if (d <= 1) {
        const v = (d * 100).toFixed(1);
        return `polygon(0% 0%, ${v}% 0%, 0% ${v}%)`;
      }

      const o = ((d - 1) * 100).toFixed(1);
      return `polygon(0% 0%, 100% 0%, 100% ${o}%, ${o}% 100%, 0% 100%)`;
    }

    let ticking = false;

    function onFrame() {
      const rect = hero!.getBoundingClientRect();
      const runway = hero!.offsetHeight - window.innerHeight;

      if (runway <= 0) {
        ticking = false;
        return;
      }

      const scrolled = Math.max(0, -rect.top);
      const progress = Math.min(1, scrolled / runway);

      afterLayer!.style.clipPath = clipAt(progress);

      /* ── Position the paint roller on the wipe edge ──
       *
       * The midpoint of the visible diagonal line is always at
       * (progress × vw, progress × vh) in pixel coordinates.
       * The roller is rotated so the handle points along the
       * viewport diagonal (direction of travel).
       */
      if (rollerEl) {
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const rx = progress * vw;
        const ry = progress * vh;

        const IMAGE_NATURAL_DEG = 62;
        const handleAngleDeg =
          Math.atan2(vh, vw) * (180 / Math.PI) - IMAGE_NATURAL_DEG;

        let rollerOpacity = 0;
        if (progress > 0 && progress < 1) {
          rollerOpacity = 1;
          if (progress < 0.045) rollerOpacity = progress / 0.045;
          else if (progress > 0.92) rollerOpacity = (1 - progress) / 0.08;
        }

        rollerEl.style.transform = `translate3d(${rx.toFixed(1)}px, ${ry.toFixed(1)}px, 0) translate(-50%, -50%) rotate(${handleAngleDeg.toFixed(1)}deg)`;
        rollerEl.style.opacity = String(rollerOpacity.toFixed(3));
      }

      if (scrollCue) {
        (scrollCue as HTMLElement).style.opacity = String(
          Math.max(0, 1 - progress * 7).toFixed(3),
        );
      }

      ticking = false;
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(onFrame);
        }
      },
      { passive: true },
    );

    onFrame();
  }
</script>
