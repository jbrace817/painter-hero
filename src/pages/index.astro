---
import Layout from "../layouts/Layout.astro";
import PainterHero2 from "../components/PainterHero2.astro";
import ServicesOverview from "../components/ServicesOverview.astro";
---

<Layout
  title="Bucks County Painters — Meticulous Craftsmanship, Stunning Results"
>
  <!-- ═══════ Navigation ═══════ -->
  <header class="nav-header" id="nav">
    <div
      class="nav-header__bar mx-auto flex max-w-[1280px] items-center justify-between px-5 py-4 sm:px-8"
    >
      <a
        href="#home"
        class="header-brand font-headline flex items-center gap-3 text-xl no-underline"
        aria-label="Bucks County Painters"
      >
        <span
          class="text-cream grid h-10 w-10 place-items-center rounded-full text-[22px] font-medium shadow-[inset_0_-6px_12px_rgba(0,0,0,0.2),0_2px_6px_rgba(14,42,43,0.2)]"
          style="background: radial-gradient(circle at 30% 30%, var(--color-teal-400), var(--color-teal-800) 75%)"
          >B</span
        >
        <span>
          <strong class="font-headline font-normal tracking-[0.01em]"
            >Bucks County Painters</strong
          >
          <small
            class="text-warm-gray mt-0.5 block font-mono text-[10px] font-medium tracking-[0.22em] uppercase"
            >Est. Doylestown · PA</small
          >
        </span>
      </a>

      <nav
        class="primary-nav hidden items-center gap-7 lg:flex"
        aria-label="Primary"
      >
        <a href="#home" class="nav-link">Home</a>
        <div class="group relative">
          <a href="#services" class="nav-link nav-link-chevron">Services</a>
          <div class="submenu">
            <a href="#services">Interior Painting</a>
            <a href="#services">Exterior Painting</a>
            <a href="#services">Decks &amp; Outbuildings</a>
            <a href="#services">Cabinet Refinishing</a>
          </div>
        </div>
        <a href="#portfolio" class="nav-link">Portfolio</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#reviews" class="nav-link lg:hidden xl:inline-flex">Reviews</a>
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="tel:+12678103352"
          class="phone-link hover:bg-ink/5 hidden items-center gap-2 rounded-full px-3 py-2 font-mono text-[13px] transition-colors md:inline-flex"
        >
          <svg
            class="h-3.5 w-3.5 text-teal-600"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
            ></path>
          </svg>
          (267) 810-3352
        </a>
        <a
          href="#contact"
          class="nav-cta text-ink hidden items-center gap-2.5 rounded-full bg-teal-500 px-5 py-3 text-sm font-semibold shadow-[0_6px_18px_-6px_rgba(79,163,157,0.6)] transition-all hover:-translate-y-px hover:bg-teal-400 lg:inline-flex"
        >
          Get Free Estimate
        </a>
        <button
          class="hamburger bg-ink/5 flex h-10 w-10 items-center justify-center rounded-lg lg:hidden"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            class="hamburger-icon"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M3 6h18M3 12h18M3 18h18"></path>
          </svg>
          <svg
            class="close-icon hidden"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M18 6L6 18M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile Menu (sibling of header for scroll-state selectors) -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu__nav" aria-label="Mobile navigation">
      <a href="#home" class="mobile-menu__link">Home</a>
      <button
        class="mobile-menu__link mobile-menu__accordion-btn"
        aria-expanded="false"
      >
        Services
        <svg
          class="mobile-menu__chevron"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="mobile-menu__sub" aria-hidden="true">
        <div class="mobile-menu__sub-inner">
          <a href="#services" class="mobile-menu__sublink">Interior Painting</a>
          <a href="#services" class="mobile-menu__sublink">Exterior Painting</a>
          <a href="#services" class="mobile-menu__sublink"
            >Decks &amp; Outbuildings</a
          >
          <a href="#services" class="mobile-menu__sublink"
            >Cabinet Refinishing</a
          >
        </div>
      </div>
      <a href="#portfolio" class="mobile-menu__link">Portfolio</a>
      <a href="#about" class="mobile-menu__link">About</a>
      <a href="#reviews" class="mobile-menu__link">Reviews</a>
    </nav>
    <div class="mobile-menu__footer">
      <a href="tel:+12678103352" class="mobile-menu__phone">
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
          ></path>
        </svg>
        (267) 810-3352
      </a>
      <a href="#contact" class="mobile-menu__cta">
        Get Free Estimate
        <span
          class="inline-block h-1.5 w-1.5 rounded-full bg-current opacity-90"
        ></span>
      </a>
    </div>
  </div>

  <main>
    <!-- ═══════ 1. Hero ═══════ -->
    <PainterHero2 />

    <!-- ═══════ 2. Trust Bar ═══════ -->
    <section class="text-cream bg-teal-900 py-7" id="trustBar">
      <div class="mx-auto max-w-[1280px] px-5 sm:px-8">
        <div class="trust-bar-grid" data-reveal>
          <div class="trust-cell">
            <div class="trust-icon">
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-[22px] w-[22px]"
              >
                <path
                  d="M12 2l2.9 6.9L22 10l-5.5 4.8L18 22l-6-3.5L6 22l1.5-7.2L2 10l7.1-1.1z"
                ></path>
              </svg>
            </div>
            <div>
              <strong class="block text-[15px] font-semibold"
                >5-star Google reviews</strong
              >
              <span class="text-cream/70 text-[13px]"
                >Over 40 verified neighbors</span
              >
            </div>
          </div>
          <div class="trust-cell">
            <div class="trust-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="h-[22px] w-[22px]"
              >
                <circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"
                ></path>
              </svg>
            </div>
            <div>
              <strong class="block text-[15px] font-semibold"
                >20+ years of craft</strong
              >
              <span class="text-cream/70 text-[13px]"
                >Since the early 2000s</span
              >
            </div>
          </div>
          <div class="trust-cell">
            <div class="trust-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="h-[22px] w-[22px]"
              >
                <path d="M3 10l9-7 9 7v10a2 2 0 01-2 2H5a2 2 0 01-2-2z"
                ></path><path d="M9 22V12h6v10"></path>
              </svg>
            </div>
            <div>
              <strong class="block text-[15px] font-semibold"
                >Locally owned</strong
              >
              <span class="text-cream/70 text-[13px]"
                >Based in Doylestown, PA</span
              >
            </div>
          </div>
          <div class="trust-cell">
            <div class="trust-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="h-[22px] w-[22px]"
              >
                <path d="M4 19V7l8-4 8 4v12"></path><path d="M4 11h16"
                ></path><path d="M9 19v-7h6v7"></path>
              </svg>
            </div>
            <div>
              <strong class="block text-[15px] font-semibold"
                >Premium paints only</strong
              >
              <span class="text-cream/70 text-[13px]"
                >Sherwin-Williams &amp; Benjamin Moore</span
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ 3. Services ═══════ -->
    <ServicesOverview />

    <!-- ═══════ 4. About Teaser ═══════ -->
    <section class="bg-cream-2 py-16 sm:py-20 md:py-24 lg:py-28" id="about">
      <div class="mx-auto max-w-[1280px] px-5 sm:px-8">
        <div class="about-grid">
          <div
            class="about-photo"
            data-reveal
            aria-label="Portrait of Ben de Lannee"
          >
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuD0WVoQkQGf9Gt_naZg94gtjLkB8lgm3HqhnkmQSz36FhvdYNEuLNGPuqhHtJKezbP0PfMUWiVo3cnSoInUni88LK_8ObxLqZihzj7eqJgoZHBe1W0oGrJ7rzTjKiMFbFxL-VUyQJX6liQdECBUDgdoFog_OEl5rb7rSfyEeU61BmxA3YvXGgFWDaknwy8SsFPnbxk-mVMbQit9enhTqFuFiwBFRJEJOxIKAYflK3CRra7etcGHs-fV-OcnZT25PT1bkgyz1b28BTQ"
              alt="Ben de Lannee, owner of Bucks County Painters"
              class="aspect-4/5 w-full rounded-[22px] object-cover shadow-lg"
              loading="lazy"
            />
            <div class="absolute top-5 right-5 flex flex-col gap-2.5">
              <div
                class="bg-cream/95 rounded-xl px-3.5 py-2.5 font-mono text-[11px] text-teal-800"
              >
                <b
                  class="font-headline text-ink mb-0.5 block text-[22px] leading-none font-normal"
                  >20+</b
                >Years painting
              </div>
              <div
                class="bg-cream/95 rounded-xl px-3.5 py-2.5 font-mono text-[11px] text-teal-800"
              >
                <b
                  class="font-headline text-ink mb-0.5 block text-[22px] leading-none font-normal"
                  >600+</b
                >Homes finished
              </div>
            </div>
          </div>

          <div class="about-copy" data-reveal>
            <span
              class="mb-3.5 block font-mono text-xs tracking-[0.18em] text-teal-600 uppercase"
              >About the owner</span
            >
            <h2
              class="font-headline text-ink mb-5 text-[clamp(32px,3.6vw,48px)] leading-[1.08]"
            >
              Ben grew up painting houses in Doylestown. He still does.
            </h2>
            <p class="text-warm-gray max-w-[62ch] text-[19px] leading-[1.55]">
              What started as a summer job during high school became a calling.
              Twenty years later, Ben de Lannee runs every job personally — from
              the first walk-through to the last drop-cloth fold. No
              subcontractors, no shortcuts, no surprises on the invoice.
            </p>
            <p class="font-headline mt-6 text-[26px] text-teal-700 italic">
              — "If it's not a finish I'd put in my own home, it's not going in
              yours."
            </p>
            <div class="about-meta-grid">
              <div>
                <b
                  class="font-headline mb-1 block text-[32px] leading-none font-normal text-teal-700"
                  >2005</b
                ><span class="text-warm-gray text-[12.5px]"
                  >Founded in Doylestown</span
                >
              </div>
              <div>
                <b
                  class="font-headline mb-1 block text-[32px] leading-none font-normal text-teal-700"
                  >100%</b
                ><span class="text-warm-gray text-[12.5px]"
                  >Owner-led projects</span
                >
              </div>
              <div>
                <b
                  class="font-headline mb-1 block text-[32px] leading-none font-normal text-teal-700"
                  >0</b
                ><span class="text-warm-gray text-[12.5px]">Subcontractors</span
                >
              </div>
            </div>
            <div class="mt-8 flex justify-center md:mt-16 xl:justify-start">
              <a
                href="#"
                class="border-ink/18 text-ink hover:border-ink inline-flex items-center gap-2.5 rounded-full border px-[22px] py-3.5 text-[15px] font-semibold transition-all hover:-translate-y-px"
              >
                Meet the full story
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                >
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ 5. Portfolio ═══════ -->
    <section class="py-16 sm:py-20 md:py-24 lg:py-28" id="portfolio">
      <div class="mx-auto max-w-[1280px] px-5 sm:px-8">
        <div
          class="mb-14 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between"
        >
          <div data-reveal>
            <span
              class="mb-3.5 block font-mono text-xs tracking-[0.18em] text-teal-600 uppercase"
              >Recent work</span
            >
            <h2
              class="font-headline text-ink text-[clamp(32px,3.6vw,48px)] leading-[1.08]"
            >
              A few projects from this year.
            </h2>
          </div>
          <a
            href="#"
            class="border-ink/18 text-ink hover:border-ink inline-flex items-center gap-2.5 rounded-full border px-[22px] py-3.5 text-sm font-semibold transition-all hover:-translate-y-px"
            data-reveal
          >
            View full gallery
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            >
          </a>
        </div>

        <div class="portfolio-grid" data-reveal>
          <div class="portfolio-item group col-span-2 row-span-2">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCM-YEBQH7bswO-5atb1gQjJ_gPOzEVRkv1q995Qh2qK6CWCez7yZ5Pg1HDkpMw0l6xNiPs1TnPX7wHFQa5rDZ5AabSKa5vbMeQ6xoSS8iffdK9EuRXlbjk_o3cBa3Lh3mXH6s84aSAW0vLZCK1sr6fzL7v2TK0L5uctZwlBK1mCpYEmy4ZZPJ0pvriZ1Y1zNfU1FeLL9JNMph7U-7KqlxKlXz_ilzz1KsQcZ0j59kWiIMHbvSWJyoi4xSlZzu4uFlwZkqbj72AM7E"
              alt="Colonial living room"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>Colonial living room</b><span>Doylestown · Interior</span>
            </div>
          </div>
          <div class="portfolio-item group row-span-2">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDJmnzHsEBONJp8EoxoUYkY8aNU96y8uqFIhTEwj5j4nmdshMU27SJDhbt0FaowcrFjfXqo8z_YHSeN3pOtDNmoc3Htma2wrhadE4Etgeodps3Z5Or8wHEnz2IlegPKHFSA5v7zjui7S-nntkebb_oqlGlHePgJDOLnYusr06MVbpm5DXi5_vf8UerT4lCjosrzdakBRHY2YivRCg1_SVJTH-yd_u41zwvVS1J4sm88fRrk2g1Cyd75pzhmeIThZ1pWwGkD-jHbdi0"
              alt="Cape Cod exterior"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>Cape Cod exterior</b><span>New Hope · Exterior</span>
            </div>
          </div>
          <div class="portfolio-item group">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuArroNn32xYtx-vxPMLq_M0qSyort1QmVSIJLQDPcnk10GAaxXODlGVVowo_QJbywYd0gC1y3EKdFqqlvX89hAdCQuVg9FIt9e7Bejf4SexP2xMJqJKiza2Elhx21xU72wM9L2bO57MNZDS5NS6djCD260wsei2AUTamuocGDmTrXdjKHeePXtNEDfP-2_qEdr8GkzpWB6zVyS7n42hvjb0auPUvWE8rUeDcVs5O6HO5xjK7rAyA8sbAETgc0pDVDXTH0TIW6YbeQA"
              alt="Cedar deck refinish"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>Cedar deck refinish</b><span>Warrington · Deck</span>
            </div>
          </div>
          <div class="portfolio-item group">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCKcQgLnJNh7IwGUxNM7wO6JBwHtgWfbTTjtcinWUzT7FqXhDj5jG7mSx9g1CSIrdH85BfV4GL2qgmwBnnv4aOQakOJN6IY1ASnY643j40CSg9YNwDBnXygU7qhaQOrTAmg-89OE63T964GlH9RmzJraYY1gwsQt8K9jfRW4LSkQUFICAeGgFAcRbA5CTYDXcVoiNa7HnPeiVXFlA4wJa5fmxIkwR3Lz0K6cz1IpX45RPaAr2xi6fGUKQeXygMo_pe0m_tpfuv09xo"
              alt="White oak cabinets"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>White oak cabinets</b><span>Solebury · Cabinetry</span>
            </div>
          </div>
          <div class="portfolio-item group col-span-2">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuC88vmPscUHBdiyVHOFybAjsDMc2cHQb6SDXK7vncVHdGAmaJTOWMcQcscZrkoRsl7R35A4BlqhLK4F2v2s0srgPLjyU-X9IAn6qPJx7ypfcPEjm7TrZBraFbSLvwU8XLrmVVaV85FVZys6ooc7LCUujJ07IOw5nFRXTFuK-43brBu36MTZBQSNkorkYk823Xva1_l7SNWpIa6My_YhjVHEOmyXW4gZWlElXq8xYsVCBKQIt9Mjes-PzWgW4odQfYf2XWVXINvPmdE"
              alt="Kitchen with navy cabinets"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>Kitchen refresh</b><span>Buckingham · Interior</span>
            </div>
          </div>
          <div class="portfolio-item group">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDyPG5J0bPo-gzfFNMicWfQu0CT2fKMGIho0evSipnk399b1HfT4bmN6x6SoCmpLyS-8ZbP_bv5i8q-zELpuaQi6a7BRMKRHY2KktFaJJev2tdZ_iWYdP411kQf2GWTRuBlDRW5yoWC_HY3nie_mcsKkzGynKQfK_9l9uNWOi_pDEZmYeh8y5qY_mcuazP0OVOLGSOhCHlfGXkinpIkoYavIKLH4XOK6SYcI01j604R_Wm0vuqvcxTJ6BrTH3Iu5sl_D3pH2vr2jYA"
              alt="Farmhouse siding"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>Farmhouse siding</b><span>Plumstead · Exterior</span>
            </div>
          </div>
          <div class="portfolio-item group">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuC4XIWQZnOZngyWNNuUKohdH3tLcuQxy0XXXA8t5TJgEluHewVBgG7nhIYRL3KSFgI41I1ftdZtcGND8s_cJRf7etvsb3h7ivNveaTjqdbly3_X8Y9wUvuuqw98EmfxPF1FzVLidD0LC4fhWT1UCo4rASkWW4-2dTER9PLzgHgFboIcDTvmkUjocUyUdu_oJHGiPkCD5DoCiD8J992C0OsO9AgWMLD2aWm-ZPhFT7Jb-GalSDMtb-pIGDpxgxg6FEn-jTVnvAg7DJs"
              alt="Primary bedroom"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>Primary bedroom</b><span>Doylestown · Interior</span>
            </div>
          </div>
          <div class="portfolio-item group">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCy1lMb9tsFrHRrTCCT_JNSNTWe_jdpkOB0RfEGMWhrHNdmo3Cok7AL4AEInCcqSmrhH9nLvGMGsqPr74PdoI2SV5gQwfsZRHNUpNeVRQxJ0K0azw06z5V6-5fVmCVvzib-a_ZZFeIZ71p0YLD1Yr9gc51iF2cGQ6Jqiak5bGF9nYTrMOJo4aFTlOyQGAGSVvey2m3IYopYofvxzMu-4PAXgMCGvCnZyGbJ_JBcJiXawvlrW7eewJ3V4_GTk3zJ-NT0g3SR81jGiYE"
              alt="Pergola & fence"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <b>Pergola &amp; fence</b><span>Chalfont · Deck</span>
            </div>
          </div>
